Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block dotfiles (.env, .git, .gitignore, ...) - keep /.well-known/ open for ACME/SSL checks
  RewriteRule "(^|/)\.(?!well-known)" - [F,L]

  # Block direct access to Composer manifests and lock file
  RewriteRule ^(composer\.json|composer\.lock)$ - [F,L]

  # Block direct access to application internals (PHP source, DB layer, storage, vendored libs, view templates).
  # /tools is intentionally NOT blocked here: tools/migrate.php must stay reachable over HTTP
  # (this is a no-SSH shared host) and enforces its own token + session checks internally.
  RewriteRule ^(app|database|storage|vendor|resources|docs)(/.*)?$ - [F,L]

  # Pretty routes for the admin panel: anything under /admin that isn't a real file/dir
  # is dispatched to the front controller, which routes it internally.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^admin(/.*)?$ admin/index.php [L]

  # Friendly blog URLs: /blog/titulo-do-post -> blog-single.php?slug=titulo-do-post
  RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-single.php?slug=$1 [L,QSA]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<FilesMatch "\.(sql|log|md)$">
  Require all denied
</FilesMatch>
